# DocGen Environment Variables
# انسخ هذا الملف إلى .env وضع قيمك الحقيقية
# cp .env.example .env

# بيئة التشغيل: dev / test / prod
DOCGEN_ENV=dev

# المفتاح السري لـ JWT (سلسلة عشوائية طويلة)
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# بيانات اعتماد Gmail لإرسال الرسائل
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# مفتاح التشفير (سلسلة عشوائية طويلة)
ENCRYPTION_SECRET=change-this-to-a-random-string-at-least-32-chars

# مفتاح OpenRouter API (اختياري)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
