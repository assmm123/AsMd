    def test_valid(self):
        result = get_engine(None)
        assert result is not None

class TestKeyInfo:
    def test_create(self):
        obj = KeyInfo("sk-or-v1-testkey12345678901234567890123456789012345678901234567890")
        assert obj is not None

    def test_masked_property(self):
        obj = KeyInfo("sk-or-v1-testkey12345678901234567890123456789012345678901234567890")
        assert obj.masked is not None
        assert '...' in obj.masked or '***' in obj.masked

    def test_default_values(self):
        obj = KeyInfo("sk-or-v1-testkey12345678901234567890123456789012345678901234567890")
        assert obj.uses == 0
        assert obj.successes == 0
        assert obj.failures == 0
        assert obj.active == True

