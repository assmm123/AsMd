        assert callable(RepairStrategies.add_setup)


class TestHealer:
    """اختبارات المعالج"""

    def test_healer_creates(self):
        """إنشاء Healer"""
        h = Healer()
        assert h is not None
        assert h.MAX_ATTEMPTS == 15

    def test_heal_broken_test(self):
        """معالجة اختبار مكسور"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as f:
            f.write("""def broken_func(x):\n    return None\n\nclass TestBroken:\n    def test_broken(self):\n        result = broken_func(42)\n        assert result is not None\n""")
            fp = f.name
        try:
            h = Healer()
            success, output = TestRunner.run_single_test(fp, 'TestBroken::test_broken')
            result = h.heal(fp, output)
            assert isinstance(result, HealResult)
            assert result.total_attempts > 0
        finally:
            for f in [fp, fp + '.healer_backup']:
                if os.path.exists(f):
                    os.unlink(f)


class TestConvenience:
    """اختبارات الدوال المساعدة"""

    def test_heal_test_function(self):
        """heal_test تعمل"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as f:
            f.write("def test_x():\n    assert False\n")
            fp = f.name
        try:
            success, output = TestRunner.run_test(fp)
            result = heal_test(fp, output)
            assert isinstance(result, HealResult)
        finally:
            for f in [fp, fp + '.healer_backup']:
                if os.path.exists(f):
                    os.unlink(f)
