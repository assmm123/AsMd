from pathlib import Path
BASE_DIR = Path(__file__).parent.parent.parent

class TestIndexHTML:
    def test_uses_main_css(self):
        content = open(BASE_DIR / 'templates/index.html').read()
        assert 'main.css' in content
    def test_uses_app_js(self):
        content = open(BASE_DIR / 'templates/index.html').read()
        assert 'app.js' in content

